{
  "name": "agentmanager",
  "version": "1.0.84",
  "description": "AI coding session orchestration dashboard — launch, monitor, and manage Claude Code & OpenAI Codex sessions from a web UI",
  "type": "module",
  "bin": {
    "agentmanager": "cli.mjs"
  },
  "files": [
    "cli.mjs",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "claude-code",
    "codex",
    "ai",
    "dashboard",
    "terminal",
    "orchestration",
    "multi-agent",
    "developer-tools",
    "cli"
  ],
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:dashboard\"",
    "dev:server": "cd server && npm run dev",
    "dev:dashboard": "cd dashboard && npm run dev",
    "dev:isolated": "bash scripts/dev-isolated.sh",
    "build": "npm run build:dashboard && npm run build:server",
    "build:server": "cd server && npm run build",
    "build:dashboard": "cd dashboard && npm run build",
    "test": "npm run test:unit",
    "test:unit": "npm run test:server && npm run test:dashboard",
    "test:server": "npm --prefix server test",
    "test:dashboard": "npm --prefix dashboard test",
    "test:coverage": "npm --prefix server run test:coverage && npm --prefix dashboard run test:coverage",
    "test:e2e": "playwright test",
    "test:all": "npm run test:coverage && npm run build && npm run test:e2e",
    "test:ci": "npm run test:all",
    "start": "cd server && npm start",
    "install:all": "npm install && cd server && npm install && cd ../dashboard && npm install",
    "clean": "cd server && rm -rf dist && cd ../dashboard && rm -rf dist",
    "deploy": "bash scripts/deploy-dev.sh",
    "deploy:ui": "npm run build:dashboard && rsync -a --delete dashboard/dist/ \"$HOME/agentmanager/dashboard/dist/\""
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@playwright/test": "^1.61.1",
    "better-sqlite3": "^12.8.0",
    "concurrently": "^9.1.0"
  },
  "author": "AI Genius Automations <support@aigeniusautomations.com>",
  "license": "Apache-2.0 WITH Commons-Clause",
  "homepage": "https://agentmanager.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ai-genius-automations/agentmanager.git"
  },
  "overrides": {
    "hono": ">=4.12.16",
    "@hono/node-server": ">=1.19.13",
    "fast-uri": ">=3.1.2",
    "ip-address": ">=10.1.1"
  },
  "dependencies": {
    "@xterm/addon-web-links": "^0.12.0"
  }
}
